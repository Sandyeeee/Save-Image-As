{
  "manifest_version": 3,
  "name": "Save Image As...",
  "version": "1.0",
  "description": "Right-click to save any image as PNG, JPG, or JPEG.\n Fully open source",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "downloads"
  ],
  "author": "Sand",

  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  }
}